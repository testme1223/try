sub print_table {
    my ($num) = @_;

    print "\nMultiplication Table for $num:\n";

    for my $i (1..10) {
        print "$num x $i = ", $num * $i, "\n";
    }
}

# Call subroutine for numbers 1 to 10
for my $n (1..10) {
    print_table($n);
}


